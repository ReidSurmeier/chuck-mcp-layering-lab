# woodblock_stack (v23-MCP)
# Editor config — applied by every editor that respects .editorconfig.
# Ruff's line-length=100 in pyproject.toml is the authoritative Python rule;
# this file mirrors it for the editor + adds YAML/Markdown rules.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,toml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
max_line_length = 100
trim_trailing_whitespace = false  # markdown line-break is two trailing spaces

[Makefile]
indent_style = tab

[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2
max_line_length = 100
